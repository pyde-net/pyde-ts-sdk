{
  "name": "pyde-ts-sdk",
  "version": "0.1.0-beta.1",
  "description": "TypeScript SDK for Pyde — the blockchain network. Connects dapps, wallets, indexers, and backend services to a Pyde node. Post-quantum crypto via pyde-crypto-wasm; type-safe ABI; wallet adapter pattern.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Pyde Network",
  "homepage": "https://pyde.network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyde-net/pyde-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/pyde-net/pyde-ts-sdk/issues"
  },
  "keywords": [
    "pyde",
    "pyde-network",
    "pyde-ts-sdk",
    "blockchain",
    "layer-1",
    "post-quantum",
    "falcon-512",
    "kyber-768",
    "ml-kem",
    "mev-resistant",
    "mysticeti",
    "wasmtime",
    "webassembly",
    "sdk",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen.d.ts",
      "import": "./dist/codegen.js"
    }
  },
  "bin": {
    "pyde-tsgen": "./dist/cli-tsgen.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build && npm run audit:prod"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.5.0",
    "pyde-crypto-wasm": "file:../pyde-crypto-wasm/pkg"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.6",
    "ws": "^8.21.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
